# Copy this file to .env and fill in your values.

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=fuel_route_planner
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── Routing ───────────────────────────────────────────────────────────────────
# GraphHopper free tier: sign up at https://www.graphhopper.com/
# 500 req/day free. Leave blank to fall back to the public OSRM server.
GRAPHHOPPER_API_KEY=

# ── Fuel data ────────────────────────────────────────────────────────────────
# Absolute path to the CSV. Defaults to <BASE_DIR>/data/fuel_prices.csv
# FUEL_CSV_PATH=/absolute/path/to/fuel_prices.csv
