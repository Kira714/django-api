# Copy this file to .env and fill in your values.

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=fuel_route_planner
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── Routing ───────────────────────────────────────────────────────────────────
# GraphHopper free tier: sign up at https://www.graphhopper.com/
# 500 req/day free. Leave blank to fall back to the public OSRM server.
GRAPHHOPPER_API_KEY=

# ── Fuel data ────────────────────────────────────────────────────────────────
# EIA Open Data API key — free sign-up at https://www.eia.gov/opendata/register.php
# Used by `python manage.py sync_fuel_prices` to pull weekly state gas prices.
# Without this key, stations fall back to the $3.50/gal placeholder loaded from
# stations.json. The app still works; prices just won't be real.
EIA_API_KEY=

# Override the stations JSON file path (defaults to data/stations.json)
# FUEL_STATIONS_JSON_PATH=/absolute/path/to/stations.json
