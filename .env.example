# Copy this file to .env and fill in your values.

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=fuel_route_planner
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── Routing ───────────────────────────────────────────────────────────────────
# GraphHopper free tier: sign up at https://www.graphhopper.com/
# 500 req/day free. Leave blank to fall back to the public OSRM server.
GRAPHHOPPER_API_KEY=

# ── Fuel data ────────────────────────────────────────────────────────────────
# Override the stations JSON file path (defaults to data/stations.json)
# FUEL_STATIONS_JSON_PATH=/absolute/path/to/stations.json

# Override fuel prices CSV path (defaults to fuel-prices-for-be-assessment.csv)
# FUEL_PRICES_CSV_PATH=/absolute/path/to/fuel-prices-for-be-assessment.csv
